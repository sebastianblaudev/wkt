# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# Supabase connection (production). Use the service_role key from your
# Supabase project settings. ROTATE this key if it was ever committed.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Master key for super-admin operations. Use a long, random string.
SUPER_ADMIN_KEY=

# Secret used to derive per-channel WebRTC signaling keys (HMAC).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SIGNAL_SECRET=

# Comma-separated list of allowed CORS origins (frontend). Leave empty for local dev.
ALLOWED_ORIGINS=

# TURN servers for WebRTC behind restrictive NAT/cellular networks.
# Recommended: run coturn via docker-compose.yml and let the server mint
# ephemeral credentials (TURN_SECRET shared with coturn). The browser never
# sees the secret. Optional build-time override below still works.
TURN_SECRET=
TURN_URLS=turn:localhost:3478?transport=udp,turn:localhost:3478?transport=tcp
TURN_EXTERNAL_IP=
VITE_TURN_URLS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Port for the server (optional, Render sets this automatically).
PORT=3000

# --- Operational AI (optional) ---
# The AI brain is a deterministic rules engine by default and works with ZERO
# API keys. To upgrade to a real LLM (natural-language summaries/insights), set
# AI_PROVIDER_URL + AI_API_KEY. OpenAI-compatible endpoint (works with Kimi/
# Moonshot: https://api.moonshot.cn/v1/chat/completions). When unset, the
# deterministic engine is used automatically.
# AI_PROVIDER_URL=https://api.moonshot.cn/v1/chat/completions
# AI_API_KEY=
# AI_MODEL=kimi-k2

# --- Production TURN (Metered / Twilio / static credentials) ---
# Used by getTurnConfig() to push TURN to clients. Prefer this over TURN_SECRET
# when you don't run your own coturn. Leave empty to use ephemeral TURN_SECRET.
# TURN_STATIC_URLS=turn:your-metered-turn-url:3478?transport=udp,turn:your-metered-turn-url:3478?transport=tcp
# TURN_STATIC_USER=
# TURN_STATIC_PASS=

